// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model SourceStoreCredential {
  id              String   @id @default(cuid())
  targetShop      String   @unique
  sourceShop      String
  encryptedToken  String
  tokenStatus     String   @default("unchecked")
  lastValidatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DefinitionSyncJob {
  id                            String              @id @default(cuid())
  sourceShop                    String
  targetShop                    String
  status                        String              @default("pending")
  totalMetafieldDefinitions     Int                 @default(0)
  totalMetaobjectDefinitions    Int                 @default(0)
  existingMetafieldDefinitions  Int                 @default(0)
  existingMetaobjectDefinitions Int                 @default(0)
  missingMetafieldDefinitions   Int                 @default(0)
  missingMetaobjectDefinitions  Int                 @default(0)
  createdMetafieldDefinitions   Int                 @default(0)
  createdMetaobjectDefinitions  Int                 @default(0)
  addedMetaobjectFields         Int                 @default(0)
  copiedMetaobjectEntries       Int                 @default(0)
  skippedMetaobjectEntries      Int                 @default(0)
  failedMetaobjectEntries       Int                 @default(0)
  conflictCount                 Int                 @default(0)
  failedCount                   Int                 @default(0)
  errorMessage                  String?
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt
  logs                          DefinitionSyncLog[]
}

model DefinitionSyncLog {
  id        String             @id @default(cuid())
  jobId     String
  itemType  String
  itemKey   String
  status    String
  message   String
  createdAt DateTime           @default(now())
  job       DefinitionSyncJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model FileSyncJob {
  id               String        @id @default(cuid())
  sourceShop       String
  targetShop       String
  status           String        @default("pending")
  totalSourceFiles Int           @default(0)
  createdCount     Int           @default(0)
  skippedCount     Int           @default(0)
  failedCount      Int           @default(0)
  errorMessage     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  logs             FileSyncLog[]
}

model FileSyncLog {
  id         String      @id @default(cuid())
  jobId       String
  status      String
  identifier  String
  message     String
  createdAt   DateTime   @default(now())
  job         FileSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model StoreConnectionHistory {
  id         String   @id @default(cuid())
  targetShop String
  sourceShop String?
  status     String
  event      String
  message    String
  createdAt  DateTime @default(now())

  @@index([targetShop, createdAt])
}
